// Template for local secrets.
//
// Setup:
//   cp Config/Secrets.example.xcconfig Config/Secrets.xcconfig
//   then fill in the values from your Supabase project's API settings.
//
// Secrets.xcconfig is gitignored so your real values are never committed.
//
// SUPABASE_HOST is the host only (no scheme); the "https://" is added in code
// because "//" starts a comment in xcconfig files.
SUPABASE_HOST = your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY = sb_publishable_your_key_here
